# Copy to .env (gitignored) and fill in your keys.
# Everything here is exported to the API, web server and agent worker
# when you run ./scripts/koi-serve.sh start.

# Workspace — данные лаборатории (отдельный каталог или git-репо).
# По умолчанию: ../koi-workspace рядом с engine (см. scripts/koi-serve.sh).
# KOI_WORKSPACE=/path/to/my-lab

# agent_chat_mode: cursor_inbox | cursor_ide | api
# cursor_inbox — Inbox-чат + watcher (рекомендуется, без API)
# cursor_ide — hooks при старте/stop агента
# api — фоновый воркер (CURSOR_API_KEY)
# KOI_AGENT_CHAT_MODE=cursor_inbox

CURSOR_API_KEY=

# Model used by the agent-chat worker (default: composer-2.5)
# KOI_AGENT_CHAT_MODEL=composer-2.5

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
